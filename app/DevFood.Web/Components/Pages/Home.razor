@page "/"

<PageTitle>DeliveryDev</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">DeliveryDev</MudText>

<MudGrid>
    @foreach (var card in _cards)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6">@card.Title</MudText>
                <MudButton Href="@card.Href" Variant="Variant.Text" Color="Color.Primary">Open</MudButton>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    private readonly (string Title, string Href)[] _cards =
    [
        ("Categories", "categories"),
        ("Restaurants", "restaurants"),
        ("Products", "products"),
        ("Customers", "customers"),
        ("Delivery Persons", "delivery-persons"),
        ("Orders", "orders")
    ];
}