@page "/customers"
@inject DevFoodApiClient Api
@inject IDialogService DialogService

<PageTitle>Customers</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Customers</MudText>

<MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenCreate" Class="mb-3">
    New Customer
</MudButton>

<MudTable Items="_items" Loading="_loading" Dense="true" Hover="true">
    <HeaderContent>
        <MudTh>Full Name</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh>Document</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.FullName</MudTd>
        <MudTd>@context.Email</MudTd>
        <MudTd>@context.PhoneNumber</MudTd>
        <MudTd>@context.Document</MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<CustomerModel> _items = [];
    private bool _loading = true;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        _loading = true;
        _items = await Api.GetCustomersAsync() ?? [];
        _loading = false;
    }

    private async Task OpenCreate()
    {
        var dialog = await DialogService.ShowAsync<CreateCustomerDialog>("New Customer");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await Load();
    }
}
