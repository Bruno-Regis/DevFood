@page "/restaurants"
@inject DevFoodApiClient Api
@inject IDialogService DialogService

<PageTitle>Restaurants</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Restaurants</MudText>

<MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenCreate" Class="mb-3">
    New Restaurant
</MudButton>

<MudTable Items="_items" Loading="_loading" Dense="true" Hover="true">
    <HeaderContent>
        <MudTh>Title</MudTh>
        <MudTh>Address</MudTh>
        <MudTh>Min. Order</MudTh>
        <MudTh>Categories</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Title</MudTd>
        <MudTd>@context.Address</MudTd>
        <MudTd>@(context.MinimumOrderAmount?.ToString("C") ?? "-")</MudTd>
        <MudTd>@CategoryNames(context.Categories)</MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<RestaurantModel> _items = [];
    private List<CategoryModel> _categories = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _categories = await Api.GetCategoriesAsync() ?? [];
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        _items = await Api.GetRestaurantsAsync() ?? [];
        _loading = false;
    }

    private string CategoryNames(List<Guid> ids)
        => string.Join(", ", _categories.Where(c => ids.Contains(c.Id)).Select(c => c.Title));

    private async Task OpenCreate()
    {
        _categories = await Api.GetCategoriesAsync() ?? [];
        var parameters = new DialogParameters { ["Categories"] = _categories };
        var dialog = await DialogService.ShowAsync<CreateRestaurantDialog>("New Restaurant", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await Load();
    }
}