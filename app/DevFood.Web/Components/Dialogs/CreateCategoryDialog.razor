@inject DevFoodApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>New Category</TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_command.Title" Label="Title" Required="true"
                          MaxLength="80"
                          Validation="@(new Func<string?, string?>(v => Validators.MinLength(v, 2, "Title")))"
                          Immediate="true" />
            <MudTextField @bind-Value="_command.Description" Label="Description" Lines="3"
                          MaxLength="500" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_submitting">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="_submitting">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private readonly CreateCategoryCommand _command = new();
    private MudForm? _form;
    private bool _submitting;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (_form is null) return;
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _submitting = true;
        try
        {
            var res = await Api.CreateCategoryAsync(_command);
            if (res.IsSuccessStatusCode)
            {
                Snackbar.Add("Category created", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to create category", Severity.Error);
            }
        }
        finally
        {
            _submitting = false;
        }
    }
}
